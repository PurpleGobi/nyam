# ── Supabase (필수) ──
# 클라이언트 노출 OK (anon + URL은 설계상 public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 절대 NEXT_PUBLIC_ prefix 금지. RLS bypass 가능
SUPABASE_SERVICE_ROLE_KEY=
# Supabase CLI/Management API 토큰 (개발용, gitignore 필수)
SUPABASE_ACCESS_TOKEN=

# ── Kakao Maps (필수) ──
# 서버 전용 (REST API 호출용)
KAKAO_REST_API_KEY=
# 클라이언트 노출 (JS SDK 키, 도메인 잠금 권장)
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── Naver Local Search API (서버 전용, 검색 fallback) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Naver Maps JavaScript SDK (클라이언트, 클라이언트 ID만 노출 OK) ──
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
# Naver Map "Client Secret"은 서버 전용. NEXT_PUBLIC_ prefix 금지!
NAVER_MAP_CLIENT_SECRET=

# ── Google ──
# 서버 전용 (Gemini Vision/Text)
GEMINI_API_KEY=
# 서버 전용 (Places API)
GOOGLE_PLACES_API_KEY=
# 서버 전용 (Custom Search Engine, 와인 라벨 이미지 검색)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# 클라이언트 노출 (Google Maps JS API, **반드시 referer 도메인 잠금**)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── 기타 ──
# Tavily (선택, 미사용시 비워둬도 됨)
TAVILY_API_KEY=

# /api/restaurants/prestige/match cron 인증용 (Bearer 토큰)
# 임의 32자+ 문자열. 호출자(예: Vercel Cron)와 공유.
PRESTIGE_MATCH_CRON_SECRET=
